{
  "name": "tempo",
  "version": "1.0.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "biome": "bun x biome check --write --unsafe ./src",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:js": "bun run scripts/build.ts",
    "build:types": "tsc -b tsconfig.json --clean && tsc -b tsconfig.json",
    "build:tsc": "tsc -d --declarationDir dist",
    "clean": "rm -rf dist",
    "dev": "bun run scripts/dev.ts",
    "done": "bun run clean && bun run biome && (bun run test || true) && bun run build",
    "format": "bun x biome format --write ./src",
    "lint": "bun x biome lint --write --unsafe ./src",
    "test": "bun test --bail --preload ./src",
    "test:noBail": "bun test --preload ./src",
    "update": "bun update --latest"
  },
  "keywords": [
    "utilities",
    "functions"
  ],
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.6",
    "@types/moment-timezone": "^0.5.30",
    "moment-timezone": "^0.6.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "bun": "latest"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": true
    }
  }
}
