{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
  },
  "include": [
    "./src",
  ],
  "exclude": [
    "dist",
    "node_modules",
    "*.ignore*",
    "./src/**/*.spec.ts",
    "./src/**/*.test.ts",
  ],
  "types": [
    "node",
    "bun",
    "express"
  ],
  "references": [
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
